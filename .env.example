# Optional backend gate. When set, every /api/* route except /api/health
# requires this value in the X-Backend-Token header.
QA_ASSISTANT_ACCESS_TOKEN=change-me

# Keep true for normal production. Set false only behind a trusted corporate
# proxy that performs TLS inspection and only when you understand the risk.
QA_ASSISTANT_VERIFY_SSL=true

# Request and fetch limits.
QA_ASSISTANT_MAX_MESSAGE_CHARS=50000
QA_ASSISTANT_MAX_IMAGE_DATA_CHARS=13500000
QA_ASSISTANT_MAX_HISTORY_MESSAGES=10
QA_ASSISTANT_MAX_HISTORY_CONTENT_CHARS=12000
QA_ASSISTANT_MAX_DOM_FETCH_BYTES=500000
QA_ASSISTANT_MAX_URL_REDIRECTS=2

# Phase 4 repo integration. Use absolute paths separated by ":" on macOS/Linux
# or ";" on Windows. Defaults to the backend process working directory.
QA_ASSISTANT_ALLOWED_REPO_ROOTS=/absolute/path/to/allowed/workspace
QA_ASSISTANT_REPO_COMMAND_TIMEOUT_SECONDS=60

# Optional provider secrets. Users can either keep keys server-side here or
# paste temporary per-provider keys in the UI sidebar.
OPENAI_API_KEY=your-openai-api-key-here
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
KIMI_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
